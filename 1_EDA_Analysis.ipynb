{
 "cells": [
  {
   "cell_type": "markdown",
   "id": "header",
   "metadata": {},
   "source": [
    "# Insurance Premium Prediction - Exploratory Data Analysis (EDA)\n",
    "\n",
    "**Objective**: Analyze insurance dataset to understand factors affecting premium charges\n",
    "\n",
    "**Dataset**: Insurance charges based on personal attributes\n",
    "\n",
    "**Goal**: Identify key patterns and relationships for building ML model"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "step1-header",
   "metadata": {},
   "source": [
    "## Step 1: Import Libraries and Load Data"
   ]
  },
  {
   "cell_type": ings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# Set visualization style\n",
    "plt.style.use('seaborn-v0_8')\n",
    "sns.set_palette(\"husl\")\n",
    "plt.rcParams['figure.figsize'] = (10, 6)\n",
    "\n",
    "print(\"Libraries imported successfully!\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "data-loading",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load dataset\n",
    "df = pd.read_csv('insurance (1).csv')\n",
    "\n",
    "print(f\"Dataset shape: {df.shape}\")\n",
    "print(f\"\\nColumns: {list(df.columns)}\")\n",
    "print(\"\\nFirst 5 rows:\")\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "basic-info",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Basic dataset information\n",
    "print(\"Dataset Info:\")\n",
    "print(f\"Rows: {len(df)}\")\n",
    "print(f\"Columns: {len(df.columns)}\")\n",
    "print(f\"\\nData types:\")\n",
    "print(df.dtypes)\n",
    "print(f\"\\nMissing values:\")\n",
    "print(df.isnull().sum())\n",
    "print(f\"\\nBasic statistics:\")\n",
    "df.describe()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "target-analysis",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Target variable (charges) analysis\n",
    "plt.figure(figsize=(12, 4))\n",
    "\n",
    "plt.subplot(1, 2, 1)\n",
    "plt.hist(df['charges'], bins=30, alpha=0.7, color='skyblue')\n",
    "plt.title('Distribution of Insurance Charges')\n",
    "plt.xlabel('Charges ($)')\n",
    "plt.ylabel('Frequency')\n",
    "\n",
    "plt.subplot(1, 2, 2)\n",
    "plt.boxplot(df['charges'])\n",
    "plt.title('Charges Box Plot')\n",
    "plt.ylabel('Charges ($)')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(f\"Charges Statistics:\")\n",
    "print(f\"Mean: ${df['charges'].mean():.2f}\")\n",
    "print(f\"Median: ${df['charges'].median():.2f}\")\n",
    "print(f\"Min: ${df['charges'].min():.2f}\")\n",
    "print(f\"Max: ${df['charges'].max():.2f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "correlation-analysis",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Correlation analysis\n",
    "# Encode categorical variables for correlation\n",
    "df_corr = df.copy()\n",
    "df_corr['sex'] = df_corr['sex'].map({'male': 1, 'female': 0})\n",
    "df_corr['smoker'] = df_corr['smoker'].map({'yes': 1, 'no': 0})\n",
    "df_corr['region'] = df_corr['region'].astype('category').cat.codes\n",
    "\n",
    "plt.figure(figsize=(8, 6))\n",
    "correlation_matrix = df_corr.corr()\n",
    "sns.heatmap(correlation_matrix, annot=True, cmap='coolwarm', center=0, fmt='.2f')\n",
    "plt.title('Feature Correlation Matrix')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(\"Correlation with charges:\")\n",
    "charges_corr = correlation_matrix['charges'].sort_values(ascending=False)\n",
    "for feature, corr in charges_corr.items():\n",
    "    if feature != 'charges':\n",
    "        print(f\"{feature}: {corr:.3f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "smoker-analysis",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Smoker analysis (most important factor)\n",
    "plt.figure(figsize=(12, 4))\n",
    "\n",
    "plt.subplot(1, 2, 1)\n",
    "smoker_charges = df.groupby('smoker')['charges'].mean()\n",
    "plt.bar(smoker_charges.index, smoker_charges.values, color=['lightgreen', 'red'])\n",
    "plt.title('Average Charges by Smoking Status')\n",
    "plt.ylabel('Average Charges ($)')\n",
    "\n",
    "plt.subplot(1, 2, 2)\n",
    "sns.boxplot(data=df, x='smoker', y='charges')\n",
    "plt.title('Charges Distribution by Smoking Status')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(\"Smoking Impact:\")\n",
    "for status, charge in smoker_charges.items():\n",
    "    print(f\"{status}: ${charge:.2f} average\")\n",
    "diff = smoker_charges['yes'] - smoker_charges['no']\n",
    "print(f\"Difference: ${diff:.2f} ({diff/smoker_charges['no']*100:.1f}% higher for smokers)\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "age-bmi-analysis",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Age and BMI analysis\n",
    "plt.figure(figsize=(12, 4))\n",
    "\n",
    "plt.subplot(1, 2, 1)\n",
    "plt.scatter(df['age'], df['charges'], alpha=0.6, color='blue')\n",
    "plt.title('Age vs Charges')\n",
    "plt.xlabel('Age')\n",
    "plt.ylabel('Charges ($)')\n",
    "\n",
    "plt.subplot(1, 2, 2)\n",
    "plt.scatter(df['bmi'], df['charges'], alpha=0.6, color='green')\n",
    "plt.title('BMI vs Charges')\n",
    "plt.xlabel('BMI')\n",
    "plt.ylabel('Charges ($)')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(f\"Age correlation with charges: {df['age'].corr(df['charges']):.3f}\")\n",
    "print(f\"BMI correlation with charges: {df['bmi'].corr(df['charges']):.3f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "categorical-analysis",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Other categorical variables\n",
    "plt.figure(figsize=(12, 4))\n",
    "\n",
    "plt.subplot(1, 2, 1)\n",
    "sex_charges = df.groupby('sex')['charges'].mean()\n",
    "plt.bar(sex_charges.index, sex_charges.values, color=['pink', 'lightblue'])\n",
    "plt.title('Average Charges by Gender')\n",
    "plt.ylabel('Average Charges ($)')\n",
    "\n",
    "plt.subplot(1, 2, 2)\n",
    "region_charges = df.groupby('region')['charges'].mean()\n",
    "plt.bar(region_charges.index, region_charges.values)\n",
    "plt.title('Average Charges by Region')\n",
    "plt.ylabel('Average Charges ($)')\n",
    "plt.xticks(rotation=45)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(\"Gender impact:\")\n",
    "for gender, charge in sex_charges.items():\n",
    "    print(f\"{gender}: ${charge:.2f}\")\n",
    "\n",
    "print(\"\\nRegion impact:\")\n",
    "for region, charge in region_charges.items():\n",
    "    print(f\"{region}: ${charge:.2f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "smoker-interaction",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Smoker interaction with age and BMI (key insight)\n",
    "plt.figure(figsize=(12, 4))\n",
    "\n",
    "plt.subplot(1, 2, 1)\n",
    "for smoker in df['smoker'].unique():\n",
    "    subset = df[df['smoker'] == smoker]\n",
    "    plt.scatter(subset['age'], subset['charges'], alpha=0.6, label=f'Smoker: {smoker}')\n",
    "plt.title('Age vs Charges by Smoking Status')\n",
    "plt.xlabel('Age')\n",
    "plt.ylabel('Charges ($)')\n",
    "plt.legend()\n",
    "\n",
    "plt.subplot(1, 2, 2)\n",
    "for smoker in df['smoker'].unique():\n",
    "    subset = df[df['smoker'] == smoker]\n",
    "    plt.scatter(subset['bmi'], subset['charges'], alpha=0.6, label=f'Smoker: {smoker}')\n",
    "plt.title('BMI vs Charges by Smoking Status')\n",
    "plt.xlabel('BMI')\n",
    "plt.ylabel('Charges ($)')\n",
    "plt.legend()\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(\"Key insight: Smoking amplifies the effect of age and BMI on charges\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "conclusions",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Key findings for model building\n",
    "print(\"=== EDA CONCLUSIONS ===\")\n",
    "print(\"\\n1. SMOKING is the strongest predictor of insurance charges\")\n",
    "print(f\"   - Smokers pay {(smoker_charges['yes']/smoker_charges['no']-1)*100:.0f}% more than non-smokers\")\n",
    "\n",
    "print(\"\\n2. AGE has positive correlation with charges\")\n",
    "print(f\"   - Correlation: {df['age'].corr(df['charges']):.3f}\")\n",
    "\n",
    "print(\"\\n3. BMI shows moderate correlation\")\n",
    "print(f\"   - Correlation: {df['bmi'].corr(df['charges']):.3f}\")\n",
    "\n",
    "print(\"\\n4. Gender and region have minimal impact\")\n",
    "\n",
    "print(\"\\n5. Feature interactions matter:\")\n",
    "print(\"   - Smoking amplifies age and BMI effects\")\n",
    "\n",
    "print(\"\\n=== MODEL RECOMMENDATIONS ===\")\n",
    "print(\"• Use smoker as primary feature\")\n",
    "print(\"• Include age and BMI as secondary features\")\n",
    "print(\"• Consider interaction terms: smoker*age, smoker*bmi\")\n",
    "print(\"• Gender and region may be less important\")\n",
    "print(\"• Target variable is right-skewed - consider log transformation\")"
   ]
  }
 ],
